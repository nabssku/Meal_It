// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user")
  accounts      Account[]
  sessions      Session[]
  
  // Basic Health Profile
  gender        String?
  age           Int?
  height        Float?
  weight        Float?
  activityLevel String?
  bodyGoal      String?
  
  // Location Profile
  address       String?
  latitude      Float?
  longitude     Float?
  
  // Budget & Financials
  dailyBudget   Int       @default(50000)
  walletBalance Int       @default(0)
  
  // Preferences & Allergies
  allergies     String[]  // Array of names
  preferences   String[]  // Array of names
  
  mealPlans     MealPlan[]
  walletLogs    WalletLog[]
  vendor        Vendor?
  orders        Order[]
  reviews       Review[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Menu {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Int
  calories    Int
  protein     Int
  fat         Int?
  carbs       Int?
  image       String?
  tags        String[] // ["Hemat", "HighProtein", "Pedas", etc]
  isAvailable Boolean  @default(true)
  stock       Int?
  category    String?  // diet, bulking, hemat, vegetarian, tinggi protein
  
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  
  mealPlanItems         MealPlanItem[]
  orderItems            OrderItem[]
  mealPlanPackageItems  MealPlanPackageItem[]
}

model Vendor {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  name        String
  description String?
  logo        String?
  address     String?
  city        String?
  contact     String?
  category    String?
  openingHours String?
  isVerified  Boolean  @default(false)
  isActive    Boolean  @default(true)
  rating      Float    @default(0)
  
  // Lokasi Restoran (Leaflet)
  latitude      Float?
  longitude     Float?
  
  // Payment Gateway Pakasir per Vendor
  pakasirSlug   String?   // Slug proyek Pakasir vendor
  pakasirApiKey String?   // API Key proyek Pakasir vendor
  
  // Delivery Settings
  deliveryFee       Int     @default(0)      // Ongkos kirim flat (Rupiah)
  isDeliveryEnabled Boolean @default(false)  // Vendor menerima antar?
  deliveryRadius    Float?                   // Radius max delivery (km, opsional)
  
  // Freemium subscription plan info
  plan                  String              @default("FREE") // "FREE", "PREMIUM"
  subscriptionStatus    String              @default("INACTIVE") // "ACTIVE", "INACTIVE", "PENDING", "EXPIRED"
  subscriptionExpiresAt DateTime?
  subscriptionOrderId   String?
  
  menus       Menu[]
  orders      Order[]
  promotions  Promotion[]
  reviews     Review[]
  mealPlanPackages MealPlanPackage[]
  advertisements Advertisement[]
  subscriptions  VendorSubscription[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MealPlanPackage {
  id            String   @id @default(cuid())
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  name          String
  description   String?
  price         Int
  duration      Int      // e.g. 1 day, 7 days
  totalCalories Int
  category      String?
  items         MealPlanPackageItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MealPlanPackageItem {
  id          String   @id @default(cuid())
  packageId   String
  package     MealPlanPackage @relation(fields: [packageId], references: [id])
  menuId      String
  menu        Menu     @relation(fields: [menuId], references: [id])
  dayNumber   Int      // 1 to duration
  mealType    String   // BREAKFAST, LUNCH, DINNER
}

model Order {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  totalAmount   Int
  status        String   @default("PENDING") // PENDING, CONFIRMED, REJECTED, PROCESSING, READY, ON_DELIVERY, COMPLETED, CANCELLED
  paymentMethod String?  // CASH, PAKASIR
  paymentStatus String   @default("PENDING") // PENDING, PAID, FAILED
  items         OrderItem[]
  notes         String?
  
  // Delivery fields
  deliveryMethod  String   @default("PICKUP")  // "PICKUP" | "DELIVERY"
  deliveryFee     Int      @default(0)
  deliveryAddress String?
  deliveryLat     Float?
  deliveryLng     Float?
  
  // Vendor response
  rejectionReason String?  // Alasan vendor menolak
  
  // Pakasir Payment Gateway
  paymentOrderId  String?  @unique  // Pakasir order_id
  paymentProject  String?  // Pakasir slug vendor
  
  // Real-time Tracking
  currentLat      Float?
  currentLng      Float?
  trackingStatus  String?  // "PREPARING" | "ON_THE_WAY" | "NEAR_LOCATION" | "ARRIVED"
  estimatedArrival DateTime?
  
  statusLogs      OrderStatusLog[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  menuId        String
  menu          Menu     @relation(fields: [menuId], references: [id])
  quantity      Int
  price         Int      // price at the time of order
}

model Review {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())
}

model Promotion {
  id            String    @id @default(cuid())
  vendorId      String
  vendor        Vendor    @relation(fields: [vendorId], references: [id])
  title         String
  description   String?
  discountRate  Int?      // percentage
  discountAmount Int?     // flat amount
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
}

model MealPlan {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @default(now()) // The day this plan is for
  
  status    String   @default("PLANNED") // PLANNED, COMPLETED, SKIPPED
  
  items     MealPlanItem[]
  
  totalPrice    Int      @default(0)
  totalCalories Int      @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MealPlanItem {
  id             String   @id @default(cuid())
  mealPlanId     String
  mealPlan       MealPlan @relation(fields: [mealPlanId], references: [id])
  menuId         String
  menu           Menu     @relation(fields: [menuId], references: [id])
  mealType       String   // BREAKFAST, LUNCH, DINNER, SNACK
  
  // Delivery & Payment (added for pickup/delivery flow)
  deliveryMethod String   @default("PICKUP")   // "PICKUP", "DELIVERY"
  status         String   @default("PENDING")  // "PENDING", "PREPARING", "READY", "PICKED_UP", "DELIVERED"
  paymentMethod  String   @default("CASH")     // "WALLET", "CASH"
  paymentStatus  String   @default("PENDING")  // "PENDING", "PAID"
  pickupCode     String?  @unique
}

model WalletLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Int
  type      String   // EXPENSE, SAVING, REFUND
  note      String?
  date      DateTime @default(now())
}

model Advertisement {
  id          String    @id @default(cuid())
  vendorId    String
  vendor      Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  title       String
  description String?
  imageUrl    String?
  targetUrl   String?
  isActive    Boolean   @default(true)
  startDate   DateTime  @default(now())
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model VendorSubscription {
  id            String   @id @default(cuid())
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  amount        Int
  status        String   @default("PENDING") // PENDING, ACTIVE, EXPIRED, FAILED
  orderId       String   @unique
  paymentMethod String?
  paymentStatus String   @default("PENDING") // PENDING, PAID, FAILED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OrderStatusLog {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  message   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
}

model SubscriptionPricing {
  id           String   @id @default(cuid())
  name         String   @default("Premium Partner")
  price        Int      @default(99000)   // harga dalam Rupiah
  description  String?
  durationDays Int      @default(30)
  isActive     Boolean  @default(true)
  updatedBy    String?  // userId admin terakhir yang mengupdate
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
